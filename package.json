{
  "name": "crm-whatsapp",
  "version": "0.1.0",
  "description": "CRM com follow-up automatico e agente de IA para primeiro atendimento via WhatsApp (Evolution API + Claude)",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "next dev",
    "dev:server": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "next build",
    "build:server": "tsc --project tsconfig.backend.json",
    "start": "next start",
    "start:server": "node dist/index.js",
    "test": "jest",
    "typecheck": "tsc --project tsconfig.backend.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "next": "^15.3.0",
    "node-cron": "^3.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/node": "^5.8.21",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
