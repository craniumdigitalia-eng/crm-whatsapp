# ===== Servidor =====
PORT=3000

# ===== Supabase Auth (portal — Story 5.2) =====
# Server-side (NUNCA exponha no browser): ignora RLS, acesso total.
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Publicas (browser): login/sessao via @supabase/ssr. Pegue em Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ===== Claude (Anthropic) =====
# Pegue sua chave em https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Modelo do agente. Opcoes: claude-opus-4-8 (melhor) | claude-sonnet-4-6 (mais barato) | claude-haiku-4-5 (mais rapido/barato)
AGENT_MODEL=claude-opus-4-8

# ===== Evolution API (WhatsApp) =====
# URL onde sua Evolution API esta rodando
EVOLUTION_URL=http://localhost:8080
# Nome da instancia que voce criou na Evolution
EVOLUTION_INSTANCE=minha-instancia
# A apikey global ou da instancia (header "apikey")
EVOLUTION_API_KEY=troque-isto

# ===== Follow-up automatico =====
# Quantas retomadas no maximo por lead, e o intervalo entre cada uma.
FOLLOWUP_MAX=30
FOLLOWUP_INTERVAL=24
FOLLOWUP_UNIT=hours
# De quanto em quanto tempo o motor verifica leads pendentes (expressao cron).
FOLLOWUP_CRON=*/5 * * * *
# Para testar rapido: FOLLOWUP_UNIT=minutes, FOLLOWUP_INTERVAL=1, FOLLOWUP_CRON=* * * * *

# Nome da sua agencia (usado pelo agente nas respostas)
COMPANY_NAME=Cranium Digital

# ===== Meta / Facebook Lead Ads (Story 5.14) =====
# Page Access Token de longa duracao da Pagina (Graph API Explorer / System User).
META_PAGE_ACCESS_TOKEN=
# App Secret do seu app Meta — usado p/ validar a assinatura do webhook leadgen.
META_APP_SECRET=
# Token de verificacao do webhook (voce escolhe; use o mesmo no painel do Meta).
META_VERIFY_TOKEN=
# ID do formulario instantaneo (Lead Ads) a importar.
META_FORM_ID=
# Versao da Graph API (opcional).
META_GRAPH_VERSION=v21.0

# ===== Google Calendar OAuth (stub — Parte 3) =====
# Crie credenciais OAuth no Google Cloud Console (Calendar API habilitada).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
